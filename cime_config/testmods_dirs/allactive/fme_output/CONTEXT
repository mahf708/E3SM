  share/util/shr_vcoarsen_mod.F90     -- shared vertical coarsening
  share/util/shr_derived_mod.F90      -- shared expression parser
  components/eam/src/control/          -- EAM wrappers (horiz_remap, vcoarsen, derived)
  components/mpas-ocean/src/           -- 3 analysis members + horiz_remap wrapper
  components/mpas-seaice/src/          -- 1 analysis member + horiz_remap wrapper
  cime_config/testmods_dirs/allactive/fme_output/  -- testmod + verify script

