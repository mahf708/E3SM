#!/bin/bash
# FME (Full Model Emulation) online output processing testmod
#
# Production configuration for ACE/Samudra coupled model emulation training
# data generation. Enables online horizontal remapping, vertical coarsening,
# derived diagnostics, and column-integrated fields.
#
# Output frequencies:
#   EAM:     6-hourly (averaged and instantaneous)
#   ELM:     6-hourly (averaged)
#   MOSART:  6-hourly (averaged)
#   MPAS-O:  daily (analysis member streams, configurable in Registry)
#   MPAS-SI: daily (analysis member stream)
#
# ---------------------------------------------------------------------------
# Map file generation (run separately before testing with horiz remap):
#
# For EAM (ne30pg2 -> 1-degree):
#   ncremap -a fv2fv_flx \
#     --src_grd=${INPUTDATA}/atm/cam/inic/homme/ne30pg2_scrip.nc \
#     --dst_grd=${INPUTDATA}/share/meshes/fv1x1_141008.nc \
#     -m map_ne30pg2_to_fv1x1_fme.nc
#
# For MPAS-O / MPAS-SI (oEC60to30 -> 1-degree):
#   ncremap -a fv2fv_flx \
#     --src_grd=${MPAS_MESH_SCRIP} \
#     --dst_grd=${INPUTDATA}/share/meshes/fv1x1_141008.nc \
#     -m map_oEC60to30_to_fv1x1_fme.nc
#
# For low-res testing (ne4pg2_oQU480):
#   ncremap -a fv2fv_flx \
#     --src_grd=ne4pg2_scrip.nc --dst_grd=fv4x5.nc \
#     -m map_ne4pg2_to_fv4x5_fme.nc
#   ncremap -a fv2fv_flx \
#     --src_grd=oQU480_scrip.nc --dst_grd=fv4x5.nc \
#     -m map_oQU480_to_fv4x5_fme.nc
# ---------------------------------------------------------------------------

./xmlchange STOP_OPTION=ndays
./xmlchange STOP_N=5

