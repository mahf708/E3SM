! ELM testmod for AI group online output processing
! Tests vertical coarsening and derived fields for soil variables
! Horizontal remapping is disabled here (requires map file);
! set hist_horiz_remap_file(2) to a valid map file path to test remapping.

hist_empty_htapes = .true.
hist_nhtfrq = -6
hist_mfilt = 1

! Derived fields: combine soil water components
elm_derived_fld_defs = 'TOTAL_SOIL_WATER=H2OSOI+SOILICE'

! 3-layer soil depth coarsening (meters)
elm_vcoarsen_zbounds = 0.0, 0.5, 2.0, 10.0
elm_vcoarsen_flds = 'TSOI', 'H2OSOI', 'TOTAL_SOIL_WATER'

! Tape 1: coarsened soil fields
hist_fincl1 =
  'TSOI_1','TSOI_2','TSOI_3',
  'H2OSOI_1','H2OSOI_2','H2OSOI_3',
  'TOTAL_SOIL_WATER_1','TOTAL_SOIL_WATER_2','TOTAL_SOIL_WATER_3',
  'TG', 'TSA'

! Tape 2: placeholder for horizontal remapping test
! Uncomment and set map file path to test remapping:
! hist_fincl2 = 'TG', 'TSA', 'RAIN', 'SNOW'
! hist_horiz_remap_file(2) = '/path/to/map_ne4pg2_to_latlon.nc'
! hist_nhtfrq(2) = -6
! hist_mfilt(2) = 1
